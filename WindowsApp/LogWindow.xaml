<Window x:Class="ESP32LoggerWin.LogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="生ログデバッグモニター" Height="400" Width="600"
        Background="#1E1E1E" Foreground="#FFFFFF"
        WindowStartupLocation="Manual">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ログ表示エリア -->
        <TextBox x:Name="LogTextBox" Grid.Row="0"
                 FontFamily="Consolas, Courier New, MS Gothic"
                 FontSize="13"
                 Background="#121212"
                 Foreground="#00FF00"
                 BorderBrush="#333333"
                 IsReadOnly="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 Margin="10" />

        <!-- コントロールバー -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10,0,10,10">
            <Button Content="ログクリア" Click="ClearButton_Click" Width="80" Height="28" Margin="0,0,10,0"
                    Background="#333333" Foreground="#FFFFFF" BorderBrush="#555555" />
            <Button Content="閉じる" Click="CloseButton_Click" Width="80" Height="28"
                    Background="#333333" Foreground="#FFFFFF" BorderBrush="#555555" />
        </StackPanel>
    </Grid>
</Window>
