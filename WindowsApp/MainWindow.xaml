<Window x:Class="ESP32LoggerWin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ESP32 多機能データロガー ダッシュボード" Height="500" Width="950"
        Background="#0E1117" Foreground="#E2E8F0"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">
    
    <Window.Resources>
        <!-- LED ネオン発光効果用スタイル -->
        <Style x:Key="NeonLed" TargetType="Ellipse">
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="Margin" Value="5,0,5,0"/>
            <Setter Property="Stroke" Value="#1A1F2C"/>
            <Setter Property="StrokeThickness" Value="1.5"/>
        </Style>

        <!-- ボタン無効化（Disabled）時の白飛びを完全に防止するカスタムスタイル -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#21262D"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4"
                                SnapsToDevicePixels="true">
                            <ContentPresenter x:Name="contentPresenter" 
                                              Focusable="False" 
                                              HorizontalAlignment="Center" 
                                              Margin="{TemplateBinding Padding}" 
                                              RecognizesAccessKey="True" 
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#30363D"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#8B949E"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="border" Property="Background" Value="#0D1117"/>
                            </Trigger>
                            <!-- 無効化されたときは、背景をダークグレー、文字を視認性の高いグレーに固定し白飛びを防止 -->
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter TargetName="border" Property="Background" Value="#1C2128"/>
                                <Setter Property="Foreground" Value="#57606A"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#21262D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <!-- ヘッダーエリア (ランプとログボタン) -->
            <RowDefinition Height="Auto" />
            <!-- メインメーターエリア -->
            <RowDefinition Height="*" />
            <!-- ボトム設定エリア -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ========================================== -->
        <!-- 1. ヘッダーエリア (インジケーターランプ等) -->
        <!-- ========================================== -->
        <Border Grid.Row="0" Background="#161B22" CornerRadius="10" Padding="12,8,12,8" Margin="0,0,0,10" BorderBrush="#30363D" BorderThickness="1">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Bluetooth 接続ランプ -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,22,0" VerticalAlignment="Center">
                        <Ellipse x:Name="BtLed" Style="{StaticResource NeonLed}" Fill="#4F5D73"/>
                        <TextBlock Text="BT接続" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Foreground="#FFFFFF"/>
                    </StackPanel>
                    
                    <!-- GPS 受信ランプ -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,22,0" VerticalAlignment="Center">
                        <Ellipse x:Name="GpsLed" Style="{StaticResource NeonLed}" Fill="#4F5D73"/>
                        <TextBlock Text="GPS受信" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Foreground="#FFFFFF"/>
                    </StackPanel>

                    <!-- GPS アンテナ接続ランプ -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,22,0" VerticalAlignment="Center">
                        <Ellipse x:Name="AntennaLed" Style="{StaticResource NeonLed}" Fill="#4F5D73"/>
                        <TextBlock Text="アンテナ接続" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Foreground="#FFFFFF"/>
                    </StackPanel>

                    <!-- 衛星捕捉数表示 -->
                    <TextBlock x:Name="SatellitesText" Text="捕捉衛星: 0 (未測位)" FontSize="13" FontWeight="SemiBold" Foreground="#58A6FF" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    <!-- UTC時刻表示 -->
                    <TextBlock x:Name="UtcTimeText" Text="UTC時刻: --:--:--" FontSize="13" FontWeight="SemiBold" Foreground="#FFFFFF" Margin="25,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 右側: ログウィンドウ開閉ボタン -->
                <Button Content="生ログモニター表示" HorizontalAlignment="Right" Width="140" Height="30"
                        Click="LogWindowButton_Click" Background="#21262D" Foreground="#FFFFFF" FontWeight="Bold"
                        BorderBrush="#8B949E" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

        <!-- ========================================== -->
        <!-- 2. メインメーターエリア (スピード＆タコ) -->
        <!-- ========================================== -->
        <Grid Grid.Row="1" Margin="0,10,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 左側：スピードメーター -->
            <Border Grid.Column="0" Background="#161B22" CornerRadius="12" BorderBrush="#30363D" BorderThickness="1" Margin="0,0,8,0" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- メーターグラフィックス -->
                    <Viewbox Grid.Row="0" Width="200" Height="200">
                        <Canvas Width="200" Height="200">
                            <!-- 外枠サークル -->
                            <Ellipse Width="190" Height="190" Canvas.Left="5" Canvas.Top="5" Stroke="#30363D" StrokeThickness="4" Fill="#0D1117"/>
                            <Ellipse Width="176" Height="176" Canvas.Left="12" Canvas.Top="12" Stroke="#21262D" StrokeThickness="1"/>
                            
                            <!-- 速度目盛り背景アーク -->
                            <Path Stroke="#1F6FEB" StrokeThickness="5" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                <Path.Data>
                                    <PathGeometry>
                                        <PathFigure StartPoint="40,165">
                                            <ArcSegment Point="160,165" Size="75,75" SweepDirection="Clockwise"/>
                                        </PathFigure>
                                    </PathGeometry>
                                </Path.Data>
                            </Path>

                            <!-- メーター針 (回転軸: 100,100) -->
                            <Line x:Name="SpeedNeedle" X1="100" Y1="100" X2="100" Y2="25" Stroke="#FF453A" StrokeThickness="3.5" StrokeEndLineCap="Round">
                                <Line.RenderTransform>
                                    <RotateTransform x:Name="SpeedRotator" Angle="-120" CenterX="100" CenterY="100"/>
                                </Line.RenderTransform>
                            </Line>
                            <Ellipse Width="14" Height="14" Canvas.Left="93" Canvas.Top="93" Fill="#FF453A"/>
                            <StackPanel Canvas.Left="60" Canvas.Top="115" Width="80" HorizontalAlignment="Center">
                                <TextBlock x:Name="SpeedText" Text="0.0" FontSize="26" FontWeight="Bold" Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                                <TextBlock Text="km/h" FontSize="13" FontWeight="Bold" Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Canvas>
                    </Viewbox>

                    <!-- スピードメーター下の最高速表示とリセットボタン -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                        <TextBlock Text="最高速: " FontSize="16" FontWeight="SemiBold" Foreground="#FFFFFF" VerticalAlignment="Center"/>
                        <TextBlock x:Name="MaxSpeedText" Text="0.0" FontSize="20" FontWeight="Bold" Foreground="#FFD60A" VerticalAlignment="Center"/>
                        <TextBlock Text=" km/h" FontSize="14" FontWeight="SemiBold" Foreground="#FFFFFF" VerticalAlignment="Center" Margin="0,0,15,0"/>
                        <Button Content="リセット" Click="ResetMaxSpeed_Click" Width="70" Height="26" FontWeight="Bold"
                                Background="#30363D" Foreground="#FFFFFF" BorderBrush="#8B949E" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 右側：タコメーター -->
            <Border Grid.Column="1" Background="#161B22" CornerRadius="12" BorderBrush="#30363D" BorderThickness="1" Margin="8,0,0,0" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- メーターグラフィックス -->
                    <Viewbox Grid.Row="0" Width="200" Height="200">
                        <Canvas Width="200" Height="200">
                            <!-- 外枠サークル -->
                            <Ellipse Width="190" Height="190" Canvas.Left="5" Canvas.Top="5" Stroke="#30363D" StrokeThickness="4" Fill="#0D1117"/>
                            <Ellipse Width="176" Height="176" Canvas.Left="12" Canvas.Top="12" Stroke="#21262D" StrokeThickness="1"/>

                            <!-- RPM目盛り背景アーク -->
                            <Path Stroke="#238636" StrokeThickness="5" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                <Path.Data>
                                    <PathGeometry>
                                        <PathFigure StartPoint="40,165">
                                            <ArcSegment Point="160,165" Size="75,75" SweepDirection="Clockwise"/>
                                        </PathFigure>
                                    </PathGeometry>
                                </Path.Data>
                            </Path>

                            <!-- メーター針 (回転軸: 100,100) -->
                            <Line x:Name="RpmNeedle" X1="100" Y1="100" X2="100" Y2="25" Stroke="#30D158" StrokeThickness="3.5" StrokeEndLineCap="Round">
                                <Line.RenderTransform>
                                    <RotateTransform x:Name="RpmRotator" Angle="-120" CenterX="100" CenterY="100"/>
                                </Line.RenderTransform>
                            </Line>
                            <Ellipse Width="14" Height="14" Canvas.Left="93" Canvas.Top="93" Fill="#30D158"/>

                            <!-- 中央のデジタル表示 -->
                            <StackPanel Canvas.Left="55" Canvas.Top="115" Width="90" HorizontalAlignment="Center">
                                <TextBlock x:Name="RpmText" Text="0" FontSize="26" FontWeight="Bold" Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                                <TextBlock Text="r/min (RPM)" FontSize="13" FontWeight="Bold" Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Canvas>
                    </Viewbox>

                    <!-- タコメーター下のPPR設定（パルス補正） -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                        <TextBlock Text="PPR補正 (パルス/回転): " FontSize="15" FontWeight="SemiBold" Foreground="#FFFFFF" VerticalAlignment="Center"/>
                        <ComboBox x:Name="PprComboBox" Width="120" Height="28" SelectedIndex="0" SelectionChanged="PprComboBox_SelectionChanged"
                                  Background="#FFFFFF" Foreground="#000000" FontSize="13" FontWeight="Bold" BorderBrush="#FF453A" BorderThickness="1.5">
                            <ComboBox.Resources>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="Foreground" Value="#000000"/>
                                    <Setter Property="Background" Value="#FFFFFF"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </ComboBox.Resources>
                            <ComboBoxItem Content="0.5 (4st単)" Tag="0.5"/>
                            <ComboBoxItem Content="1.0 (2st単)" Tag="1.0"/>
                            <ComboBoxItem Content="2.0 (マルチ)" Tag="2.0"/>
                            <ComboBoxItem Content="3.0" Tag="3.0"/>
                            <ComboBoxItem Content="4.0" Tag="4.0"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ========================================== -->
        <!-- 3. ボトム設定エリア -->
        <!-- ========================================== -->
        <Border Grid.Row="2" Background="#161B22" CornerRadius="10" Padding="15,10,15,10" BorderBrush="#30363D" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- 左側：COM接続設定 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="接続ポート (Bluetooth COM):" FontSize="14" FontWeight="Bold" Foreground="#FFFFFF" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="ComPortComboBox" Width="100" Height="28" Margin="0,0,8,0" FontSize="13" FontWeight="Bold"
                              Background="#FFFFFF" Foreground="#000000" BorderBrush="#FF453A" BorderThickness="1.5" DropDownOpened="ComPortComboBox_DropDownOpened">
                        <ComboBox.Resources>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Foreground" Value="#000000"/>
                                <Setter Property="Background" Value="#FFFFFF"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </ComboBox.Resources>
                    </ComboBox>
                    <Button x:Name="ConnectButton" Content="接続" Click="ConnectButton_Click" Width="70" Height="28" Margin="0,0,5,0"
                            Background="#238636" Foreground="#FFFFFF" BorderBrush="#2EA44F" FontSize="13" FontWeight="Bold" Cursor="Hand"/>
                    <Button x:Name="DisconnectButton" Content="切断" Click="DisconnectButton_Click" Width="70" Height="28" IsEnabled="False"
                            Background="#DA3633" Foreground="#FFFFFF" BorderBrush="#F85149" FontSize="13" FontWeight="Bold" Cursor="Hand"/>
                </StackPanel>

                <!-- 右側：データ保存先設定 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="ログ保存フォルダ:" FontSize="14" FontWeight="Bold" Foreground="#FFFFFF" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox x:Name="SaveDirTextBox" Width="280" Height="28" IsReadOnly="True" Margin="0,0,8,0" FontSize="13" FontWeight="SemiBold"
                             Background="#0D1117" Foreground="#FFFFFF" BorderBrush="#8B949E" VerticalContentAlignment="Center" Padding="5,0,5,0"/>
                    <Button Content="参照..." Click="BrowseFolder_Click" Width="70" Height="28" FontWeight="Bold"
                            Background="#21262D" Foreground="#FFFFFF" BorderBrush="#8B949E" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
